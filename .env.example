# Copy to web/.env.local for local dev

# JWT (generate: openssl rand -base64 32)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
DEVICE_TOKEN_PEPPER=change-me-device-pepper-min-16

# Database — local file (free, zero setup). For Vercel use Turso (see README).
DATABASE_URL=file:./data/dopamine.db

# Optional Turso (production on Vercel)
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-token

# First admin account (created on seed if no users exist)
CREATOR_EMAIL=you@example.com
CREATOR_PASSWORD=change-me-strong-password

# Public site URL (for CORS / links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# Launcher deep link scheme
NEXT_PUBLIC_LAUNCHER_SCHEME=dopamine

# GitHub releases (download buttons on landing)
NEXT_PUBLIC_GITHUB_RELEASES=https://github.com/veaix/dopamine-MinecraftLauncher/releases/latest
